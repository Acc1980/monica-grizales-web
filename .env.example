# MongoDB Atlas (usado por inscripciones)
MONGODB_URI=mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/monica-grizales?retryWrites=true&w=majority

# SMTP - Correo de contacto (Google Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contacto@monicagrizales.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
CONTACT_EMAIL=contacto@monicagrizales.com

# URL del sitio (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://monicagrizales.com

# Entorno
NODE_ENV=production
